# Strava OAuth (used once Strava approves us out of Single Player Mode).
# Until then, leave STRAVA_DIRECT_OAUTH_ENABLED=false and let users connect
# via Path A (per-user API key) or Path B (CSV upload).
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
NEXT_PUBLIC_STRAVA_REDIRECT_URI=http://localhost:3000/api/auth/callback
STRAVA_DIRECT_OAUTH_ENABLED=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://irvtnbpqtphuexhpgmrl.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Session signing (generate with: openssl rand -hex 32)
SESSION_SECRET=

# Optional: Claude API for dashboard narrative polish
ANTHROPIC_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
